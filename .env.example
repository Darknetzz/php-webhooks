# =============================================================================
# Application
# =============================================================================

APP_ENV=production
APP_DEBUG=0

# Base URL for the app (no trailing slash). Used for links, redirects, and
# webhook URLs when APP_URL_PUBLIC is not set.
#
#   • Direct access with path (e.g. http://web01/webhooks/public):
#     APP_URL=http://web01/webhooks/public
#
#   • Behind reverse proxy, no path in browser (e.g. https://webhooks.example.com):
#     APP_URL=https://webhooks.example.com
#
#   • Both: set APP_URL to the proxy URL; direct access is detected automatically.
APP_URL=http://localhost

# Optional. Subpath where the app is served (e.g. webhooks/public for
# http://host/webhooks/public/). Only set if links or redirects are wrong;
# the app usually detects this from the request.
APP_BASE_PATH=

# Optional. Public URL for webhook endpoints shown in the UI and curl examples.
# Set when APP_URL is internal (e.g. http://backend/) but webhooks must be
# called from the internet at a different URL. If unset, APP_URL is used.
APP_URL_PUBLIC=

# Optional. Secret key for signing sessions and cookies. Set to a long random
# string in production.
APP_SECRET=


# =============================================================================
# Database (SQLite by default)
# =============================================================================

DB_DRIVER=sqlite
DB_PATH=data/database.sqlite


# =============================================================================
# Optional: MySQL (when DB_DRIVER=mysql)
# =============================================================================

# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=webhooks
# DB_USER=
# DB_PASSWORD=
# DB_CHARSET=utf8mb4


# =============================================================================
# Optional: Docker Hub (for scripts/docker-build-push.sh)
# =============================================================================

# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=


# =============================================================================
# Optional: Git repo URL for version link in footer
# =============================================================================

# GIT_REPO_URL=https://github.com/owner/repo
