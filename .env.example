APP_ENV=production
APP_DEBUG=0
APP_URL=http://localhost
APP_SECRET=

# Optional: for scripts/docker-build-push.sh (push image to Docker Hub without interactive login)
# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=

# Database: sqlite (default) or mysql
DB_DRIVER=sqlite
DB_PATH=data/database.sqlite

# Optional: Git repo URL for version link in footer (e.g. https://github.com/owner/repo)
# GIT_REPO_URL=

# MySQL (when DB_DRIVER=mysql)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=webhooks
# DB_USER=
# DB_PASSWORD=
# DB_CHARSET=utf8mb4
