# Include this in <yourserver>'s default vhost (or in a conf.d file) so that
# http://<yourserver>/webhooks/public/login (and any path under /webhooks/public) runs the app.
# Without this, the server serves the doc root index.php instead.
#
# On Debian/Ubuntu: copy to /etc/apache2/conf-available/webhooks-subpath.conf
# then: sudo a2enconf webhooks-subpath && sudo systemctl reload apache2
#
# Adjust the paths if your app is not under /var/www/html/webhooks.

<IfModule mod_alias.c>
    Alias /webhooks/public /var/www/html/webhooks/public
</IfModule>
<Directory /var/www/html/webhooks/public>
    Options -Indexes +FollowSymLinks
    AllowOverride All
    Require all granted
</Directory>
